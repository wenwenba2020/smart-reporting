{
  "classifications": [
    {
      "categoryCode": "sales_data",
      "categoryName": "销售数据",
      "description": "销售报表、业绩数据、客户交易记录等",
      "supportedFormats": [".xlsx", ".xls", ".csv", ".txt"],
      "extractRules": {
        "fields": [
          {"name": "period", "label": "统计周期", "type": "string"},
          {"name": "totalRevenue", "label": "总收入", "type": "number"},
          {"name": "totalOrders", "label": "总订单数", "type": "number"},
          {"name": "topProducts", "label": "热销产品", "type": "array"},
          {"name": "regionalBreakdown", "label": "区域分布", "type": "object"}
        ],
        "summaryPrompt": "请从以下销售数据中提取关键指标和趋势分析。"
      }
    },
    {
      "categoryCode": "chat_export",
      "categoryName": "聊天记录",
      "description": "企业微信、钉钉等聊天工具导出的聊天记录",
      "supportedFormats": [".txt", ".csv", ".json"],
      "extractRules": {
        "fields": [
          {"name": "participants", "label": "参与人员", "type": "array"},
          {"name": "dateRange", "label": "日期范围", "type": "object"},
          {"name": "messageCount", "label": "消息总数", "type": "number"},
          {"name": "keyTopics", "label": "关键话题", "type": "array"},
          {"name": "actionItems", "label": "待办事项", "type": "array"}
        ],
        "summaryPrompt": "请从以下聊天记录中提取关键讨论话题和待办事项。"
      }
    },
    {
      "categoryCode": "meeting_notes",
      "categoryName": "会议纪要",
      "description": "会议记录、纪要文档等",
      "supportedFormats": [".txt", ".docx", ".md"],
      "extractRules": {
        "fields": [
          {"name": "meetingDate", "label": "会议日期", "type": "string"},
          {"name": "attendees", "label": "参会人员", "type": "array"},
          {"name": "agenda", "label": "议程", "type": "array"},
          {"name": "decisions", "label": "决议", "type": "array"},
          {"name": "actionItems", "label": "行动项", "type": "array"}
        ],
        "summaryPrompt": "请从以下会议纪要中提取关键决议和行动项。"
      }
    },
    {
      "categoryCode": "project_report",
      "categoryName": "项目报告",
      "description": "项目进度报告、里程碑文档等",
      "supportedFormats": [".txt", ".docx", ".md", ".xlsx"],
      "extractRules": {
        "fields": [
          {"name": "projectName", "label": "项目名称", "type": "string"},
          {"name": "period", "label": "报告周期", "type": "string"},
          {"name": "progress", "label": "进度百分比", "type": "number"},
          {"name": "milestones", "label": "里程碑", "type": "array"},
          {"name": "risks", "label": "风险项", "type": "array"},
          {"name": "nextSteps", "label": "下一步计划", "type": "array"}
        ],
        "summaryPrompt": "请从以下项目报告中提取进度、风险和下一步计划。"
      }
    }
  ]
}
