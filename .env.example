# ── LLM API ──────────────────────────────────────────────────────────────────
# OpenRouter（所有 LLM 调用的统一入口，必填）
# 注册: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 可选：其他 LLM 提供商
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── 网页调研 API ──────────────────────────────────────────────────────────────
# Exa（默认 provider）注册: https://exa.ai
EXA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Tavily（备用 provider）注册: https://tavily.com
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 安全配置 ──────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_random_64_char_hex_string_here
JWT_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# 多个地址用逗号分隔，生产环境改为真实域名
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 文件存储 ──────────────────────────────────────────────────────────────────
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./projects

# ── 字体 & 脚本路径 ───────────────────────────────────────────────────────────
FONTS_DIR=./fonts
PPT_MASTER_SKILL_DIR=./backend/skills/ppt-master

# ── 智能体模型绑定（走 OpenRouter）────────────────────────────────────────────
LLM_API_PROVIDER=openrouter
LLM_PLANNER_MODEL=z-ai/glm-5.1
LLM_COPYWRITER_MODEL=deepseek/deepseek-v3.2
LLM_DESIGNER_MODEL=z-ai/glm-5.1
LLM_EFFECTS_MODEL=qwen/qwen3.5-9b

# ── LLM 超时配置 ──────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# ── 可选：WaveSpeed（图像生成，暂未接入）─────────────────────────────────────
WAVESPEED_API_KEY=
